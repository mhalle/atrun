{
  "lexicon": 1,
  "id": "dev.atrun.yank",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["subject", "createdAt"],
        "properties": {
          "subject": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef",
            "description": "The dev.atrun.module record being yanked."
          },
          "reason": {
            "type": "string",
            "maxLength": 1024,
            "description": "Why this version was yanked."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
