{
  "lexicon": 1,
  "id": "dev.atrun.module",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["createdAt", "resolved"],
        "properties": {
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "ecosystem": {
            "type": "ref",
            "ref": "#ecosystem"
          },
          "package": {
            "type": "string",
            "maxLength": 256
          },
          "resolved": {
            "type": "array",
            "items": { "type": "ref", "ref": "#depEntry" },
            "maxLength": 2048
          },
          "derivedFrom": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef"
          }
        }
      }
    },
    "ecosystem": {
      "type": "union",
      "refs": ["#pythonEcosystem", "#nodeEcosystem"]
    },
    "pythonEcosystem": {
      "type": "object",
      "properties": {
        "platform": {
          "type": "string",
          "maxLength": 64
        }
      }
    },
    "nodeEcosystem": {
      "type": "object",
      "required": ["engine"],
      "properties": {
        "engine": {
          "type": "string",
          "maxLength": 32
        }
      }
    },
    "depEntry": {
      "type": "object",
      "required": ["packageName", "packageVersion", "sha256", "url"],
      "properties": {
        "packageName": {
          "type": "string",
          "maxLength": 256
        },
        "packageVersion": {
          "type": "string",
          "maxLength": 64
        },
        "sha256": {
          "type": "string",
          "maxLength": 64
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "source": {
          "type": "ref",
          "ref": "com.atproto.repo.strongRef"
        }
      }
    }
  }
}
