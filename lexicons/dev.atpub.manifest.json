{
  "lexicon": 1,
  "id": "dev.atpub.manifest",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["createdAt", "resolved"],
        "properties": {
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "package": {
            "type": "string",
            "maxLength": 256
          },
          "version": {
            "type": "string",
            "maxLength": 64
          },
          "description": {
            "type": "string",
            "maxLength": 1024
          },
          "license": {
            "type": "string",
            "maxLength": 128
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "packageType": {
            "type": "string",
            "description": "Type of package contained in this manifest.",
            "knownValues": [
              "dev.atpub.defs#pythonPackage",
              "dev.atpub.defs#npmPackage",
              "dev.atpub.defs#rustCrate",
              "dev.atpub.defs#goModule",
              "dev.atpub.defs#dataset",
              "dev.atpub.defs#document",
              "dev.atpub.defs#container"
            ]
          },
          "tool": {
            "type": "string",
            "description": "The tool that created this manifest, e.g. 'atrun@0.14.0'.",
            "maxLength": 128
          },
          "metadata": {
            "type": "object",
            "description": "Free-form metadata specific to the package type. Keys use camelCase per AT Protocol conventions."
          },
          "resolved": {
            "type": "array",
            "items": { "type": "ref", "ref": "#depEntry" },
            "maxLength": 2048
          },
          "derivedFrom": {
            "type": "array",
            "description": "Records this manifest derives from. Typically one entry linking to the previous version.",
            "items": { "type": "ref", "ref": "com.atproto.repo.strongRef" },
            "maxLength": 512
          }
        }
      }
    },
    "depEntry": {
      "type": "object",
      "required": ["name", "version", "hash", "url"],
      "properties": {
        "name": {
          "type": "string",
          "maxLength": 256
        },
        "version": {
          "type": "string",
          "maxLength": 64
        },
        "hash": {
          "type": "string",
          "maxLength": 256
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "dependencies": {
          "type": "array",
          "description": "Direct dependencies as name@version strings",
          "items": { "type": "string", "maxLength": 320 },
          "maxLength": 256
        },
        "source": {
          "type": "ref",
          "ref": "com.atproto.repo.strongRef"
        }
      }
    }
  }
}
