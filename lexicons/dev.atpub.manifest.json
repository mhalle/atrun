{
  "lexicon": 1,
  "id": "dev.atpub.manifest",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["createdAt"],
        "properties": {
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "package": {
            "type": "string",
            "maxLength": 256
          },
          "version": {
            "type": "string",
            "maxLength": 64
          },
          "description": {
            "type": "string",
            "maxLength": 10240
          },
          "license": {
            "type": "string",
            "description": "SPDX license identifier or expression (e.g. 'MIT', 'Apache-2.0', 'CC-BY-4.0').",
            "maxLength": 128
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "packageType": {
            "type": "string",
            "description": "Type of package contained in this manifest.",
            "knownValues": [
              "dev.atpub.defs#pythonPackage",
              "dev.atpub.defs#npmPackage",
              "dev.atpub.defs#rustCrate",
              "dev.atpub.defs#goModule",
              "dev.atpub.defs#dataset",
              "dev.atpub.defs#document",
              "dev.atpub.defs#container"
            ]
          },
          "tool": {
            "type": "string",
            "description": "The tool that created this manifest, e.g. 'atrun@0.14.0'.",
            "maxLength": 128
          },
          "metadata": {
            "type": "object",
            "description": "Free-form metadata specific to the package type. Keys use camelCase per AT Protocol conventions."
          },
          "root": {
            "type": "integer",
            "description": "Index of the primary artifact in the artifacts array."
          },
          "artifacts": {
            "type": "array",
            "items": { "type": "ref", "ref": "#artifact" },
            "maxLength": 2048
          },
          "derivedFrom": {
            "type": "array",
            "description": "Records this manifest derives from. Typically one entry linking to the previous version.",
            "items": { "type": "ref", "ref": "com.atproto.repo.strongRef" },
            "maxLength": 512
          }
        }
      }
    },
    "artifact": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Canonical unique identifier from the artifact's native system (e.g. DICOM UID, DOI, purl).",
          "maxLength": 512
        },
        "name": {
          "type": "string",
          "maxLength": 256
        },
        "version": {
          "type": "string",
          "maxLength": 64
        },
        "digest": {
          "type": "string",
          "description": "Content digest in algo:hex format (e.g. sha256:abcdef...).",
          "maxLength": 256
        },
        "urls": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "maxLength": 32,
          "description": "Download URLs, evaluated first to last."
        },
        "artifactType": {
          "type": "string",
          "description": "Type of this artifact.",
          "maxLength": 128
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "integer" },
          "maxLength": 256,
          "description": "Indices of direct dependencies in the artifacts array."
        },
        "metadata": {
          "type": "object",
          "description": "Free-form metadata specific to this artifact."
        },
        "ref": {
          "type": "ref",
          "ref": "com.atproto.repo.strongRef",
          "description": "Reference to this artifact's own dev.atpub.manifest record."
        }
      }
    }
  }
}
